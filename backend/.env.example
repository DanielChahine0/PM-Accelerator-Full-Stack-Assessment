# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/weather_db

# OpenWeatherMap API (https://openweathermap.org/api - free tier)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# YouTube Data API v3 (https://console.developers.google.com)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google Maps Embed API Key (https://console.developers.google.com)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# App settings
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
